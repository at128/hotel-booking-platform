{
  "ConnectionStrings": {
    "DefaultConnection": "Server=PROGRAMMER;Database=HotelBooking;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "JWT": {
    "Secret": "",
    "Issuer": "HotelBookingApi",
    "Audience": "HotelBookingClient",
    "ExpiryMinutes": 15
  },
  "BookingSettings": {
    "CheckoutHoldMinutes": 10,
    "TaxRate": 0.15,
    "CancellationFreeHours": 24,
    "CancellationFeePercent": 0.30,
    "MaxAdvanceBookingDays": 365
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "ForwardedHeaders": {
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "Swagger": {
    "Enabled": false
  },

  "RefreshToken": {
    "ExpiryDays": 7,
    "TokenBytes": 64
  },
  "CookieSettings": {
    "RefreshTokenCookieName": "hb_rt",
    "RefreshTokenExpiryDays": 7,
    "SecureOnly": true,
    "SameSite": "Strict",
    "Path": "/api"
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": "",
    "Currency": "usd"
  },
  "PaymentUrls": {
    "SuccessUrlTemplate": "https://your-frontend.com/booking/{0}/success",
    "CancelUrlTemplate": "https://your-frontend.com/booking/{0}/cancel"
  },
  "Jobs": {
    "ExpirePendingPayments": {
      "Enabled": true,
      "IntervalSeconds": 60,
      "BatchSize": 100
    }
  },
  "Email": {
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUser": "",
    "SmtpPassword": "",
    "FromAddress": "noreply@hotelbooking.com",
    "FromName": "HotelBooking",
    "UseSsl": true
  },
  "Uploads": {
    "HotelImages": {
      "MaxFileBytes": 5242880,
      "MaxWidth": 4096,
      "MaxHeight": 4096,
      "MaxPixels": 16000000,
      "JpegQuality": 85,
      "MaxImagesPerHotel": 100
    }
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200",
    "Username": "elastic",
    "Password": "changeme",
    "HotelIndexName": "hotels",
    "AllowInvalidCertificates": true,
    "EnableSemanticSearch": true,
    "SyncIntervalMinutes": 5,
    "NumberOfShards": 1,
    "NumberOfReplicas": 0
  },
  "Embedding": {
    "BaseUrl": "http://localhost:8000",
    "EmbeddingsEndpoint": "/embeddings",
    "Model": "all-MiniLM-L6-v2",
    "Dimensions": 384,
    "TimeoutSeconds": 30
  }
}
