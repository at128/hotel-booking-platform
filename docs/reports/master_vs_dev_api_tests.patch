+        response.StatusCode.Should().Be(HttpStatusCode.NoContent);
+
+        var oldLoginResponse = await _factory.CreateClient().PostAsJsonAsync(
+            "/api/v1/auth/login",
+            new LoginRequest(email, oldPassword));
